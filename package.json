{
  "name": "kisah-keluarga",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "bootstrap:admin": "node scripts/bootstrap-admin-user.mjs",
    "clean:fixtures": "ts-node scripts/clean-fixture-data.ts",
    "test": "npm run test:e2e",
    "test:e2e": "cross-env NODE_ENV=test ENABLE_TEST_AUTH_BOOTSTRAP=true playwright test",
    "test:smoke": "cross-env NODE_ENV=test ENABLE_TEST_AUTH_BOOTSTRAP=true playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:dev-login": "npm run test:e2e:dev-login:disabled && npm run test:e2e:dev-login:enabled",
    "test:e2e:dev-login:disabled": "cross-env NODE_ENV=test ENABLE_TEST_AUTH_BOOTSTRAP=true ENABLE_DEV_DUMMY_LOGIN=false playwright test tests/e2e/dev-login-disabled.spec.ts",
    "test:e2e:dev-login:enabled": "cross-env NODE_ENV=test ENABLE_TEST_AUTH_BOOTSTRAP=true ENABLE_DEV_DUMMY_LOGIN=true playwright test tests/e2e/dev-login-enabled.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.2",
    "tailwindcss": "^4.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
