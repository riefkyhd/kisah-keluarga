# ==========================================
# Public env (aman untuk client/browser)
# ==========================================
# URL app aktif (preview/prod menyesuaikan domain deployment).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Login utama memakai email + password (magic-link hanya fallback cadangan).

# ==========================================
# Server-only secret (JANGAN expose ke client)
# ==========================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# Opsional untuk script bootstrap admin (atau pakai argumen CLI)
# ==========================================
# BOOTSTRAP_ADMIN_EMAIL=admin@keluarga.com
# BOOTSTRAP_ADMIN_PASSWORD=ganti-dengan-password-kuat

# ==========================================
# Dev/Test-only flags (WAJIB false di production)
# ==========================================
# Emergency/demo-only: bypass auth dan perlakukan semua akses sebagai admin.
# Saat true, app akan memakai SUPABASE_SERVICE_ROLE_KEY di server.
ENABLE_AUTH_BYPASS=false
# Opsional: tentukan auth user id yang dipakai sebagai actor bypass.
# Jika kosong, app akan mencari user dengan role admin dari public.user_roles.
# AUTH_BYPASS_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Opsional: email label untuk actor bypass.
# AUTH_BYPASS_EMAIL=bypass-admin@kisah-keluarga.local

# Dev-only: aktifkan login dummy lokal tanpa OTP inbox.
ENABLE_DEV_DUMMY_LOGIN=false
# Test runner only: bootstrap auth Playwright helper.
ENABLE_TEST_AUTH_BOOTSTRAP=false
